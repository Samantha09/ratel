GATEWAY_URL=ws://127.0.0.1:8787

# 出牌决策委托给 Python dou-dizhu-agent 的 POST /play(本进程只做 WebSocket 壳)。
# 留空则回退到本进程内置 LLM(下方 MINIMAX_* 配置)。调用失败/超时一律回退规则牌。
PLAY_AGENT_URL=http://127.0.0.1:8000

# 以下为内置 LLM(仅在 PLAY_AGENT_URL 为空时用于出牌;抢地主始终用启发式)
# minimax | anthropic | openai | ollama | mock
LLM_PROVIDER=minimax
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
# 出牌专用模型,默认高速变体以缩短推理延迟(抢地主用启发式不调模型)
PLAY_MODEL=MiniMax-M2.7-highspeed
# 出牌硬超时(毫秒),超时回退规则牌,避免回合卡死(对 play-agent 与内置 LLM 都生效)
PLAY_TIMEOUT_MS=20000
LLM_TEMPERATURE=0.3

AGENT_COUNT=2
AGENT_NICKNAME_PREFIX=robot
