GATEWAY_URL=ws://127.0.0.1:8787

# minimax | anthropic | openai | ollama | mock
LLM_PROVIDER=minimax
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
# 出牌专用模型,默认高速变体以缩短推理延迟(抢地主用启发式不调模型)
PLAY_MODEL=MiniMax-M2.7-highspeed
# 出牌 LLM 硬超时(毫秒),超时回退规则牌,避免回合卡死
PLAY_TIMEOUT_MS=20000
LLM_TEMPERATURE=0.3

AGENT_COUNT=2
AGENT_NICKNAME_PREFIX=robot
